---
interface Props {
  chart: string;
}

const { chart } = Astro.props;
---

<div class="mermaid-container">
  <pre><code>{chart}</code></pre>
</div>

<style>
  .mermaid-container {
    overflow-x: auto;
    text-align: center;
    margin: 1.5rem 0;
    padding: 1rem;
    background: var(--code-bg);
    border-radius: 8px;
  }
  .mermaid-container pre {
    margin: 0;
    overflow-x: auto;
    text-align: left;
    white-space: pre-wrap;
  }
</style>
